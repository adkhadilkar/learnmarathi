{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Marathi Literacy Lesson",
  "type": "object",
  "required": [
    "id",
    "level",
    "title",
    "targetSkills",
    "warmup",
    "teach",
    "practice",
    "apply",
    "reward",
    "assets"
  ],
  "properties": {
    "id": { "type": "string" },
    "level": { "type": "string" },
    "title": { "type": "string" },
    "targetSkills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "durationMinutes": { "type": "number", "minimum": 1 },
    "warmup": {
      "type": "object",
      "required": ["prompt", "activity"],
      "properties": {
        "prompt": { "type": "string" },
        "activity": { "type": "string" }
      }
    },
    "teach": {
      "type": "object",
      "required": ["explanation", "examples"],
      "properties": {
        "explanation": { "type": "string" },
        "examples": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "practice": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "instructions"],
        "properties": {
          "type": { "type": "string" },
          "instructions": { "type": "string" },
          "items": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "apply": {
      "type": "object",
      "required": ["prompt", "expected"],
      "properties": {
        "prompt": { "type": "string" },
        "expected": { "type": "array", "items": { "type": "string" } }
      }
    },
    "reward": {
      "type": "object",
      "required": ["type", "label"],
      "properties": {
        "type": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "assets": {
      "type": "object",
      "properties": {
        "audio": { "type": "array", "items": { "type": "string" } },
        "images": { "type": "array", "items": { "type": "string" } },
        "strokePaths": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
