[
  {
    "id": "story-1",
    "title": "ससा आणि कासव",
    "titleEnglish": "The Hare and the Tortoise",
    "level": "beginner",
    "emoji": "🐢",
    "coverImage": "/images/stories/story-1-cover.svg",
    "sentences": [
      {
        "id": "story-1-s1",
        "marathi": "एक ससा जंगलात राहत होता.",
        "english": "A rabbit lived in a forest.",
        "audio": "/audio/stories/story-1-s1.mp3"
      },
      {
        "id": "story-1-s2",
        "marathi": "तो खूप वेगाने पळत असे.",
        "english": "He used to run very fast.",
        "audio": "/audio/stories/story-1-s2.mp3"
      },
      {
        "id": "story-1-s3",
        "marathi": "एक कासव हळूहळू चालत होते.",
        "english": "A tortoise was walking slowly.",
        "audio": "/audio/stories/story-1-s3.mp3"
      },
      {
        "id": "story-1-s4",
        "marathi": "सशाने कासवाला शर्यतीसाठी आव्हान दिले.",
        "english": "The rabbit challenged the tortoise to a race.",
        "audio": "/audio/stories/story-1-s4.mp3"
      },
      {
        "id": "story-1-s5",
        "marathi": "शर्यत सुरू झाली.",
        "english": "The race started.",
        "audio": "/audio/stories/story-1-s5.mp3"
      },
      {
        "id": "story-1-s6",
        "marathi": "ससा पुढे गेला आणि झाडाखाली झोपला.",
        "english": "The rabbit went ahead and slept under a tree.",
        "audio": "/audio/stories/story-1-s6.mp3"
      },
      {
        "id": "story-1-s7",
        "marathi": "कासव हळूहळू पुढे गेले.",
        "english": "The tortoise slowly moved ahead.",
        "audio": "/audio/stories/story-1-s7.mp3"
      },
      {
        "id": "story-1-s8",
        "marathi": "कासव शर्यत जिंकले!",
        "english": "The tortoise won the race!",
        "audio": "/audio/stories/story-1-s8.mp3"
      },
      {
        "id": "story-1-s9",
        "marathi": "बोध: हळू पण खात्री.",
        "english": "Moral: Slow and steady wins the race.",
        "audio": "/audio/stories/story-1-s9.mp3"
      }
    ]
  },
  {
    "id": "story-2",
    "title": "तहानलेला कावळा",
    "titleEnglish": "The Thirsty Crow",
    "level": "beginner",
    "emoji": "🪶",
    "coverImage": "/images/stories/story-2-cover.svg",
    "sentences": [
      {
        "id": "story-2-s1",
        "marathi": "एक कावळा खूप तहानलेला होता.",
        "english": "A crow was very thirsty.",
        "audio": "/audio/stories/story-2-s1.mp3"
      },
      {
        "id": "story-2-s2",
        "marathi": "त्याला एक बरणी दिसली.",
        "english": "He saw a pot.",
        "audio": "/audio/stories/story-2-s2.mp3"
      },
      {
        "id": "story-2-s3",
        "marathi": "बरणीत थोडेच पाणी होते.",
        "english": "There was very little water in the pot.",
        "audio": "/audio/stories/story-2-s3.mp3"
      },
      {
        "id": "story-2-s4",
        "marathi": "कावळ्याची चोच पाण्यापर्यंत पोहोचत नव्हती.",
        "english": "The crow's beak could not reach the water.",
        "audio": "/audio/stories/story-2-s4.mp3"
      },
      {
        "id": "story-2-s5",
        "marathi": "त्याने एक कल्पना काढली.",
        "english": "He came up with an idea.",
        "audio": "/audio/stories/story-2-s5.mp3"
      },
      {
        "id": "story-2-s6",
        "marathi": "त्याने दगड बरणीत टाकले.",
        "english": "He dropped pebbles into the pot.",
        "audio": "/audio/stories/story-2-s6.mp3"
      },
      {
        "id": "story-2-s7",
        "marathi": "पाणी वर आले!",
        "english": "The water came up!",
        "audio": "/audio/stories/story-2-s7.mp3"
      },
      {
        "id": "story-2-s8",
        "marathi": "कावळ्याने पाणी प्यायले.",
        "english": "The crow drank the water.",
        "audio": "/audio/stories/story-2-s8.mp3"
      },
      {
        "id": "story-2-s9",
        "marathi": "बोध: बुद्धी हे बळ आहे.",
        "english": "Moral: Intelligence is strength.",
        "audio": "/audio/stories/story-2-s9.mp3"
      }
    ]
  },
  {
