        "audio": "/audio/stories/story-3-s3.mp3"
      },
      {
        "id": "story-3-s4",
        "marathi": "उंदराने विनंती केली: 'मला सोडा, एक दिवस मी तुमची मदत करेन.'",
        "english": "The mouse pleaded: 'Let me go, one day I will help you.'",
        "audio": "/audio/stories/story-3-s4.mp3"
      },
      {
        "id": "story-3-s5",
        "marathi": "सिंहाने उंदराला सोडले.",
        "english": "The lion let the mouse go.",
        "audio": "/audio/stories/story-3-s5.mp3"
      },
      {
        "id": "story-3-s6",
        "marathi": "काही दिवसांनी, सिंह जाळ्यात अडकला.",
        "english": "After a few days, the lion got trapped in a net.",
        "audio": "/audio/stories/story-3-s6.mp3"
      },
      {
        "id": "story-3-s7",
        "marathi": "उंदराने जाळे कुरतडून सिंहाला सोडवले.",
        "english": "The mouse gnawed through the net and freed the lion.",
        "audio": "/audio/stories/story-3-s7.mp3"
      },
      {
        "id": "story-3-s8",
        "marathi": "बोध: कोणीही लहान नसतो.",
        "english": "Moral: No one is too small to help.",
        "audio": "/audio/stories/story-3-s8.mp3"
      }
    ]
  },
