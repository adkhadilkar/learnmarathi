      {
        "id": "story-4-s5",
        "marathi": "त्याने तोंड उघडले तेव्हा हाड पाण्यात पडले.",
        "english": "When he opened his mouth, the bone fell into the water.",
        "audio": "/audio/stories/story-4-s5.mp3"
      },
      {
        "id": "story-4-s6",
        "marathi": "बोध: लोभ हानिकारक असतो.",
        "english": "Moral: Greed is harmful.",
        "audio": "/audio/stories/story-4-s6.mp3"
      }
    ]
  },
